# Hummingbot API — environment template
#
# Local dev: copy to `.env` in this repo (or run `make setup`).
# Production server: copy to `/opt/hummingbot-stack/.secrets/env` and pass to compose:
#   docker compose -f docker-compose.prod.yml --env-file ../.secrets/env up -d
#
# chmod 600 ../.secrets/env — never commit real secrets.

# ─── Image (production) ───────────────────────────────────────────────────────
# Set automatically by GitHub Actions deploy; for manual deploys set explicitly:
# HUMMINGBOT_API_IMAGE=ghcr.io/<your-github-username>/hummingbot-api:latest

# ─── API auth ─────────────────────────────────────────────────────────────────
USERNAME=admin
PASSWORD=change_me_api_password
CONFIG_PASSWORD=change_me_hummingbot_config_password
DEBUG_MODE=false

# ─── MQTT (must match EMQX dashboard users if you change defaults) ───────────
BROKER_USERNAME=admin
BROKER_PASSWORD=change_me_mqtt_password

# ─── PostgreSQL (dedicated hummingbot-api instance) ───────────────────────────
# POSTGRES_USER must stay `hbot` unless you edit init-db.sql grants.
POSTGRES_USER=hbot
POSTGRES_PASSWORD=change_me_db_password
POSTGRES_DB=hummingbot_api

# API connection string — use hostname `postgres` inside Docker; password must match POSTGRES_PASSWORD.
DATABASE_URL=postgresql+asyncpg://hbot:change_me_db_password@postgres:5432/hummingbot_api

# ─── Bot containers (API in Docker + docker.sock on Linux) ───────────────────
# Absolute path to *this repo on the host* so child bind mounts use the same files as ./bots.
# Laptop: /home/you/.../hummingbot-api  |  Server: /opt/hummingbot-stack/hummingbot-api
DOCKER_HOST_PROJECT_ROOT=

# ─── Gateway (same host as hummingbot-stack gateway compose) ─────────────────
GATEWAY_URL=http://host.docker.internal:15888

# ─── Optional: CI / server — start Gateway via API after deploy (no legacy compose) ─
# Set true to run POST /gateway/start from deploy.yml after the API container is healthy.
GATEWAY_POST_START=false
# Image must match what you build in the hummingbot repo workflow (hummingbot-gateway).
# HUMMINGBOT_GATEWAY_IMAGE=ghcr.io/<your-github-username>/hummingbot-gateway:latest
